#!/usr/bin/env bash
# Pre-commit hook — runs quality checks before every commit.
# Setup: mise run setup   (or: git config core.hooksPath .githooks)

# Silence locale warnings that pollute the git output
export LC_ALL=C
export LANG=C

set -uo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

FAILED=()

run_step() {
  local label="$1"
  shift
  printf "  %-20s" "$label"
  if output=$("$@" 2>&1); then
    printf "${GREEN}✓${NC}\n"
  else
    printf "${RED}✗${NC}\n"
    FAILED+=("$label|||$output")
  fi
}

echo ""
echo "🔒 Running pre-commit checks..."
echo ""

# 1. Format — auto-format and re-stage the changed files
printf "  %-20s" "gofmt"
changed_files=$(gofmt -l . 2>&1)
if [ -n "$changed_files" ]; then
  gofmt -w .
  while IFS= read -r f; do
    if git diff --cached --name-only | grep -qF "$f"; then
      git add "$f"
    fi
  done <<< "$changed_files"
  printf "${YELLOW}auto-fixed${NC} $(echo "$changed_files" | wc -l | tr -d ' ') file(s)\n"
else
  printf "${GREEN}✓${NC}\n"
fi

# 2. Vet
run_step "go vet" go vet ./...

# 3. Lint (requires golangci-lint)
if command -v golangci-lint &>/dev/null; then
  run_step "golangci-lint" golangci-lint run ./...
else
  printf "  %-20s${YELLOW}skipped (not installed)${NC}\n" "golangci-lint"
fi

# 4. Tests
run_step "go test" go test ./...

# ── Summary ───────────────────────────────────────────────────────────────────

if [ ${#FAILED[@]} -eq 0 ]; then
  echo ""
  echo "✅ All checks passed!"
  echo ""
  exit 0
fi

echo ""
echo "${BOLD}${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "${BOLD}${RED} ✗ Commit blocked — ${#FAILED[@]} check(s) failed${NC}"
echo "${BOLD}${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

for entry in "${FAILED[@]}"; do
  label="${entry%%|||*}"
  output="${entry##*|||}"
  echo ""
  echo "${BOLD}▶ $label${NC}"
  echo "─────────────────────────────────────────────────────"
  echo "$output"
done

echo ""
echo "${RED}Fix the errors above, then commit again.${NC}"
echo ""
exit 1
