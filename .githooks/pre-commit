#!/usr/bin/env bash
# Pre-commit hook — runs quality checks before every commit.
# Setup: mise run setup   (or: git config core.hooksPath .githooks)

export LC_ALL=C
export LANG=C

set -uo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

FAILED=()
TMPDIR_HOOK=$(mktemp -d)
trap 'rm -rf "$TMPDIR_HOOK"' EXIT

# ── Helpers ───────────────────────────────────────────────────────────────────

run_step() {
  local label="$1"
  shift
  printf "  %-20s" "$label"
  if output=$("$@" 2>&1); then
    printf "${GREEN}✓${NC}\n"
  else
    printf "${RED}✗${NC}\n"
    FAILED+=("$label|||$output")
  fi
}

# Returns only .go files that are staged (added or modified)
staged_go_files() {
  git diff --cached --name-only --diff-filter=ACM | grep '\.go$'
}

# ── Start ─────────────────────────────────────────────────────────────────────

echo ""
echo "🔒 Running pre-commit checks..."
echo ""

# 1. gofmt — only staged files
printf "  %-20s" "gofmt"

mapfile -t files < <(staged_go_files)

if [ ${#files[@]} -eq 0 ]; then
  printf "${GREEN}✓${NC} (no Go files staged)\n"
else
  needs_fmt=()
  for f in "${files[@]}"; do
    [[ -f "$f" ]] || continue
    if ! gofmt -l "$f" | grep -q .; then
      : # already formatted
    else
      needs_fmt+=("$f")
    fi
  done

  if [ ${#needs_fmt[@]} -gt 0 ]; then
    gofmt -w "${needs_fmt[@]}"
    git add "${needs_fmt[@]}"
    printf "${YELLOW}auto-fixed${NC} ${#needs_fmt[@]} file(s)\n"
  else
    printf "${GREEN}✓${NC}\n"
  fi
fi

# 2. go vet
run_step "go vet" go vet ./...

# 3. golangci-lint
if command -v golangci-lint &>/dev/null; then
  run_step "golangci-lint" golangci-lint run ./...
else
  printf "  %-20s${YELLOW}skipped (not installed)${NC}\n" "golangci-lint"
fi

# 4. Tests — com race detector e timeout
run_step "go test" go test -race -timeout 60s ./...

# ── Summary ───────────────────────────────────────────────────────────────────

if [ ${#FAILED[@]} -eq 0 ]; then
  echo ""
  echo "✅ All checks passed!"
  echo ""
  exit 0
fi

echo ""
echo "${BOLD}${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "${BOLD}${RED} ✗ Commit blocked — ${#FAILED[@]} check(s) failed${NC}"
echo "${BOLD}${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

for entry in "${FAILED[@]}"; do
  label="${entry%%|||*}"
  output="${entry##*|||}"
  echo ""
  echo "${BOLD}▶ $label${NC}"
  echo "─────────────────────────────────────────────────────"
  echo "$output"
done

echo ""
echo "${RED}Fix the errors above, then commit again.${NC}"
echo ""
exit 1