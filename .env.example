# PostgreSQL connection string (required)
DATABASE_URL=postgres://user:password@localhost:5432/goingcrypt?sslmode=disable

# PostgreSQL connection pool (optional)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_MAX_IDLE_TIME=5m

# JWT signing secret — use a long random string in production (required)
JWT_SECRET=change-me-to-a-long-random-secret

# JWT issuer claim (optional, default: goingcrypt)
JWT_ISSUER=goingcrypt

# HTTP server port (optional, default: 8080)
PORT=8080
