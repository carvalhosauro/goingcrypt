# =============================================================================
# goingcrypt — environment variables
# Copy this file to .env and fill in the values before running.
# NEVER commit the real .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (used by both the DB container and the app)
# ---------------------------------------------------------------------------
POSTGRES_DB=goingcrypt
POSTGRES_USER=goingcrypt
POSTGRES_PASSWORD=change-me-strong-password

# Full DSN consumed by the Go app and the migrate binary
DATABASE_URL=postgres://goingcrypt:change-me-strong-password@postgres:5432/goingcrypt?sslmode=disable

# Connection pool tuning (optional — defaults shown)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_MAX_IDLE_TIME=5m

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ISSUER=goingcrypt

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------
PORT=8080
# Port exposed on the Docker host (can differ from the container port)
HOST_PORT=8080

# ---------------------------------------------------------------------------
# Build metadata (injected during docker compose build)
# ---------------------------------------------------------------------------
VERSION=dev
COMMIT=unknown
BUILD_DATE=unknown
